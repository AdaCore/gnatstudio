<?xml version="1.0"?>
<GNATPROVE>

  <target model="gnatfuzz-fuzz-model"
          name="Run GNATfuzz to find counterexample candidates"
          category="GNATprove">
    <in-menu>FALSE</in-menu>
    <iconname>gps-build-all-symbolic</iconname>
    <launch-mode>MANUALLY_WITH_DIALOG</launch-mode>
    <read-only>TRUE</read-only>
    <command-line>
      <arg>gnatfuzz</arg>
      <arg>fuzz-everything</arg>
      <arg>test</arg>
      <arg>-P%PP</arg>
    </command-line>
    <output-parsers>
      {output_parsers}
    </output-parsers>
  </target>

</GNATPROVE>
